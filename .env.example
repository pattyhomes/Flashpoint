# Copy to .env and fill in values. Never commit .env.

APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true

DATABASE_URL=sqlite:///../data/flashpoint.db

INGESTION_INTERVAL_SECONDS=1800
MOCK_DATA_ENABLED=true

# Ingestion source: "mock" (dev/demo) or "gdelt" (production real-data)
INGEST_SOURCE=mock

# ---------------------------------------------------------------------------
# Desktop shell (optional overrides — Pi deployment)
# ---------------------------------------------------------------------------
# FLASHPOINT_FULLSCREEN=1    # open fullscreen window; default windowed (Mac dev)
# FLASHPOINT_DEV_QUIT=0      # skip custom dev quit shortcut; default enabled (note: platform-level quit paths unaffected)
# FLASHPOINT_MANAGED=1       # skip subprocess management; services managed externally (systemd/autostart)
# FLASHPOINT_PORTRAIT=1      # FUTURE USE ONLY — not yet wired to any geometry or orientation behavior

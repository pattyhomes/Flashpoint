# Copy to .env and fill in values. Never commit .env.

APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true

DATABASE_URL=sqlite:///../data/flashpoint.db

INGESTION_INTERVAL_SECONDS=1800
MOCK_DATA_ENABLED=true

# Ingestion source: "mock" (dev/demo) or "gdelt" (production real-data)
INGEST_SOURCE=mock

# ---------------------------------------------------------------------------
# Event Registry (supplementary ingestion source — runs alongside GDELT/mock)
# ---------------------------------------------------------------------------
# EVENT_REGISTRY_ENABLED=false
# EVENT_REGISTRY_API_KEY=                          # required when enabled
# EVENT_REGISTRY_INTERVAL_SECONDS=1800             # fetch cadence (default 30 min)
# EVENT_REGISTRY_LOOKBACK_HOURS=6                  # article lookback window
# EVENT_REGISTRY_MAX_RECORDS=100                   # max articles per run
# EVENT_REGISTRY_US_ONLY=true                      # restrict to US location URI
# EVENT_REGISTRY_MIN_CLASSIFICATION_SCORE=0.6      # reject below this threshold
# EVENT_REGISTRY_MIN_LOCATION_PRECISION=city       # venue | city | state
# EVENT_REGISTRY_CREATE_NEW_EVENTS=false           # discover novel events (off by default)
# EVENT_REGISTRY_MAX_NEW_EVENTS_PER_RUN=10         # cap on new events per run
# EVENT_REGISTRY_MAX_CONFIDENCE_UNCORROBORATED=0.58 # confidence cap for ER-only events

# ---------------------------------------------------------------------------
# Desktop shell (optional overrides — Pi deployment)
# ---------------------------------------------------------------------------
# FLASHPOINT_FULLSCREEN=1    # open fullscreen window; default windowed (Mac dev)
# FLASHPOINT_DEV_QUIT=0      # skip custom dev quit shortcut; default enabled (note: platform-level quit paths unaffected)
# FLASHPOINT_MANAGED=1       # skip subprocess management; services managed externally (systemd/autostart)
# FLASHPOINT_PORTRAIT=1      # FUTURE USE ONLY — not yet wired to any geometry or orientation behavior

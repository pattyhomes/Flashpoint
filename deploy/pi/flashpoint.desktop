[Desktop Entry]
Type=Application
Name=Flashpoint
Comment=Flashpoint unrest monitoring shell — autostart on login
# Runs in Pi-managed mode: fullscreen, dev quit shortcut disabled.
# Backend is expected to be running as the flashpoint-backend systemd user service.
# Repo path is substituted by deploy/pi/install.sh — do not edit the installed copy.
Exec=bash __REPO_ROOT__/scripts/pi_start.sh
X-GNOME-Autostart-enabled=true
